{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "CC Scripts",
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "colors": {
    "primary": "#155EEF",
    "light": "#155EEF",
    "dark": "#155EEF"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#09090B"
    }
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "pages": [
      "index"
    ],
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Minigames",
            "pages": [
              "cc_minigames/index",
              "cc_minigames/installation",
              "cc_minigames/usage",
              "cc_minigames/minigames",
              "cc_minigames/advanced/control-panel",
              "cc_minigames/advanced/dui-sessions",
              "cc_minigames/advanced/frequency-multiplayer"
            ]
          },
          {
            "group": "Heist Contracts",
            "pages": [
              "cc_heistcontracts/index",
              "cc_heistcontracts/installation",
              "cc_heistcontracts/configuration",
              "cc_heistcontracts/registering-contracts",
              "cc_heistcontracts/dashboard",
              "cc_heistcontracts/marketplace",
              "cc_heistcontracts/training",
              "cc_heistcontracts/admin"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "pages": [
          "changelog"
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Store",
          "href": "https://cc-scripts.com",
          "icon": "store"
        },
        {
          "anchor": "Discord",
          "href": "https://discord.gg/cc-scripts",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/cc-logo.svg",
    "dark": "/logo/cc-logo.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@cc-scripts.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Store",
      "href": "https://cc-scripts.com"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/cc-scripts",
      "x": "https://x.com/ccscripts"
    }
  }
}
